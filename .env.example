# ============================================
# Bookkeeping Dashboard - Environment Variables
# ============================================

# === Production (Vercel) ===
# PostgreSQL connection string (Neon)
# Get one free at https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Clerk authentication (required for production)
# Get keys at https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...  # Same as above — needed by the Vite frontend
# CLERK_API_URL=https://api.clerk.com  # Optional — only needed for custom Clerk API URLs

# CORS origin
CORS_ORIGIN=https://book-keeper-dashboard-v2.vercel.app

# === Local Development ===
# No DATABASE_URL needed - uses SQLite by default
# PORT=3001
