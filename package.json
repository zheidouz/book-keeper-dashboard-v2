{
  "name": "book-keeper-dashboard-v2",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "vercel-build": "cd client && npm run build",
    "postinstall": "node -e \"!process.env.VERCEL&&require('child_process').execSync('cd client&&npm install&&cd ../server&&npm install',{stdio:'inherit',shell:true})\"",
    "dev": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev"
  },
  "dependencies": {
    "@clerk/clerk-sdk-node": "^4.13.23",
    "@neondatabase/serverless": "^1.1.0",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.10.0"
  }
}
